# ════════════════════════════════════════════════════════════════
# 🐳 Docker Environment Configuration
# ════════════════════════════════════════════════════════════════
# Copy this file: cp .env.docker .env
# Then fill in your actual values
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 🔑 GOOGLE OAUTH (REQUIRED)
# ════════════════════════════════════════════════════════════════
# Get from: https://console.cloud.google.com/
# Frontend & Backend must use the SAME Client ID
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ════════════════════════════════════════════════════════════════
# 🔐 JWT SECRET (REQUIRED)
# ════════════════════════════════════════════════════════════════
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=YOUR_JWT_SECRET_HERE_GENERATE_WITH_PYTHON

# ════════════════════════════════════════════════════════════════
# 🖼️  IMAGE & API KEYS (REQUIRED FOR FULL FEATURES)
# ════════════════════════════════════════════════════════════════
# Get from: https://platform.openai.com/
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE

# Get from: https://imagekit.io/
IMAGEKIT_PRIVATE_KEY=private_YOUR_IMAGEKIT_PRIVATE_KEY_HERE
IMAGEKIT_PUBLIC_KEY=public_YOUR_IMAGEKIT_PUBLIC_KEY_HERE
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/YOUR_ENDPOINT_HERE

# ════════════════════════════════════════════════════════════════
# 🌐 API & FRONTEND CONFIGURATION
# ════════════════════════════════════════════════════════════════
# Frontend API URL (for Docker, use service name: http://backend:8000)
VITE_API_URL=http://backend:8000

# ════════════════════════════════════════════════════════════════
# 🏗️  APPLICATION ENVIRONMENT
# ════════════════════════════════════════════════════════════════
ENVIRONMENT=development
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# ════════════════════════════════════════════════════════════════
# 💾 DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════
# For development (SQLite):
DATABASE_URL=sqlite:///./memoriesbuilder.db

# For production (PostgreSQL - uncomment when ready):
# DATABASE_URL=postgresql://memoraai:secure_password@postgres:5432/memoraai

# ════════════════════════════════════════════════════════════════
# 🔒 CORS & SECURITY
# ════════════════════════════════════════════════════════════════
CORS_ORIGINS=http://localhost:5173,http://frontend:5173

# ════════════════════════════════════════════════════════════════
# ⏱️  TIMEOUTS & LIMITS
# ════════════════════════════════════════════════════════════════
JWT_EXPIRATION_HOURS=24
MAX_REQUEST_SIZE=52428800
MAX_UPLOAD_BYTES=10485760
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3
