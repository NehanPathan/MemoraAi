# 🔐 MemoraAI Backend Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file: cp .env.example .env
# Then replace all PLACEHOLDER values with your actual keys
# ═══════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 🔑 REQUIRED KEYS (Get from Google Cloud Console)
# ════════════════════════════════════════════════════════════════

# Google OAuth2 - Client ID
# Get from: https://console.cloud.google.com/ → Credentials
# Format: 123456789-abc123xyz.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=PASTE_YOUR_GOOGLE_CLIENT_ID_HERE

# Google OAuth2 - Client Secret
# Get from: https://console.cloud.google.com/ → Credentials
# Format: GOCSPX-xxxxxxxxxxxxxx
GOOGLE_OAUTH_CLIENT_SECRET=PASTE_YOUR_GOOGLE_CLIENT_SECRET_HERE

# JWT Secret - Secure random token
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Format: MlH9x_vQ8kL7pZ2nR5tW9mY3qJ6sCxB1-vD4eF5gH
JWT_SECRET=PASTE_YOUR_JWT_SECRET_HERE

# ════════════════════════════════════════════════════════════════
# ⚙️  APPLICATION SETTINGS
# ════════════════════════════════════════════════════════════════

# Application Environment
# Options: development, staging, production
ENVIRONMENT=development

# CORS Settings (Origins allowed to access this API)
# Development: http://localhost:5173
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173

# ════════════════════════════════════════════════════════════════
# 🖼️  IMAGE GENERATION & STORAGE (Optional - for full features)
# ════════════════════════════════════════════════════════════════

# OpenAI API Key - For generating images
# Get from: https://platform.openai.com/ → API Keys
# Format: sk-proj-xxxxxxxxxxxxx
# OPTIONAL: Leave as is until you want to generate images
OPENAI_API_KEY=sk-PASTE_YOUR_OPENAI_KEY_HERE

# ImageKit Settings - For storing uploaded/generated images
# Get from: https://imagekit.io/ → Developer → API Keys
# OPTIONAL: Leave as is for basic testing
IMAGEKIT_PRIVATE_KEY=private_PASTE_YOUR_IMAGEKIT_PRIVATE_KEY_HERE
IMAGEKIT_PUBLIC_KEY=public_PASTE_YOUR_IMAGEKIT_PUBLIC_KEY_HERE
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/PASTE_YOUR_IMAGEKIT_ENDPOINT_HERE

# ════════════════════════════════════════════════════════════════
# 📊 DATABASE CONFIGURATION
# ════════════════════════════════════════════════════════════════

# SQLite (default for development - no setup needed!)
DATABASE_URL=sqlite:///./memoriesbuilder.db

# PostgreSQL (for production - uncomment when deploying)
# DATABASE_URL=postgresql://user:password@localhost:5432/memoraai

# ════════════════════════════════════════════════════════════════
# 🔒 SECURITY & LIMITS
# ════════════════════════════════════════════════════════════════

# Maximum request size (50MB default)
MAX_REQUEST_SIZE=52428800

# Maximum file upload size (10MB default)
MAX_UPLOAD_BYTES=10485760

# Rate limiting: requests per hour per IP
RATE_LIMIT_REQUESTS=100

# Rate limiting: time window in seconds (1 hour)
RATE_LIMIT_WINDOW=3600

# ════════════════════════════════════════════════════════════════
# 📝 LOGGING & DEBUGGING
# ════════════════════════════════════════════════════════════════

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: text or json
LOG_FORMAT=text

# Show SQL queries (only for debugging!)
SQL_ECHO=false

# ════════════════════════════════════════════════════════════════
# ⏱️  TIMEOUT & RETRY SETTINGS
# ════════════════════════════════════════════════════════════════

# OpenAI request timeout (seconds)
OPENAI_TIMEOUT=60

# Number of retry attempts for failed requests
OPENAI_MAX_RETRIES=3

# JWT token expiration (hours)
JWT_EXPIRATION_HOURS=24

# ════════════════════════════════════════════════════════════════
# 📝 QUICK SETUP GUIDE
# ════════════════════════════════════════════════════════════════
#
# 1. Get JWT Secret (30 seconds):
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
#    Paste output into: JWT_SECRET
#
# 2. Get Google Keys (2 minutes):
#    Go to: https://console.cloud.google.com/
#    Create OAuth Client ID → Web Application
#    Add URLs: http://localhost:5173 and http://localhost:8000
#    Copy Client ID and Client Secret
#    Paste into: GOOGLE_OAUTH_CLIENT_ID and GOOGLE_OAUTH_CLIENT_SECRET
#
# 3. Optional - Get OpenAI Key:
#    Go to: https://platform.openai.com/
#    Create API Key
#    Paste into: OPENAI_API_KEY
#
# 4. Optional - Get ImageKit Keys:
#    Go to: https://imagekit.io/
#    Get API Keys from Developer section
#    Paste into: IMAGEKIT_PRIVATE_KEY, IMAGEKIT_PUBLIC_KEY, IMAGEKIT_URL_ENDPOINT
#
# ════════════════════════════════════════════════════════════════
