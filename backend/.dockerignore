# ════════════════════════════════════════════════════════════════
# 🔒 Backend Docker Ignore
# ════════════════════════════════════════════════════════════════
# Files/directories to exclude from Docker build context
# ════════════════════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 🐍 Python
# ════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.hypothesis/
*.cover
.tox/
.nox/

# ════════════════════════════════════════════════════════════════
# 🔐 Environment & Secrets
# ════════════════════════════════════════════════════════════════
.env
.env.local
.env.*.local
.env.production
.env.staging
!.env.example
secrets/
.secrets/

# ════════════════════════════════════════════════════════════════
# 💾 Virtual Environment
# ════════════════════════════════════════════════════════════════
venv/
env/
ENV/
.venv
.venv/
pip-log.txt

# ════════════════════════════════════════════════════════════════
# 🗂️ IDE & Editor
# ════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace
.vim/
.emacs*

# ════════════════════════════════════════════════════════════════
# 📊 Database
# ════════════════════════════════════════════════════════════════
*.db
*.sqlite
*.sqlite3
postgres_data/
data/

# ════════════════════════════════════════════════════════════════
# 📝 Logs
# ════════════════════════════════════════════════════════════════
logs/
*.log
*.log.*

# ════════════════════════════════════════════════════════════════
# 🔧 Version Control
# ════════════════════════════════════════════════════════════════
.git
.gitignore
.gitattributes
.github/

# ════════════════════════════════════════════════════════════════
# 📦 Build & CI/CD
# ════════════════════════════════════════════════════════════════
.gitlab-ci.yml
.travis.yml
Jenkinsfile
.circleci/
.github/workflows/
docker-compose.*.yml
Makefile
makefile

# ════════════════════════════════════════════════════════════════
# 📚 Documentation & Test Files
# ════════════════════════════════════════════════════════════════
README.md
CHANGELOG.md
LICENSE
docs/
tests/
test/
*.md
.pytest_cache/
.mypy_cache/

# ════════════════════════════════════════════════════════════════
# 🚫 Large Files
# ════════════════════════════════════════════════════════════════
*.tar
*.tar.gz
*.zip
*.rar
*.7z

# ════════════════════════════════════════════════════════════════
# 📂 Cache & Temporary
# ════════════════════════════════════════════════════════════════
.cache/
.tmp/
temp/
tmp/
*.tmp
.mypy_cache
.pytest_cache
*.pyc
.scrapy

# ════════════════════════════════════════════════════════════════
# 🔍 Development
# ════════════════════════════════════════════════════════════════
.vscode-server
.vscode-remote
remote-repo/
node_modules/
npm-debug.log
yarn-error.log

# ════════════════════════════════════════════════════════════════
# 📱 System
# ════════════════════════════════════════════════════════════════
.DS_Store
Thumbs.db
*.bak
*~
.~*

# ════════════════════════════════════════════════════════════════
